---
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishDate?: Date;
  updatedDate?: Date;
  schema?: Record<string, unknown>[];
}

const props = Astro.props;
---
<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <script is:inline>
      // Set the theme before the page paints so there is no flash of the
      // wrong colors. Reads the saved choice; falls back to the system.
      (function () {
        try {
          var saved = localStorage.getItem('qtb-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (e) {
          // localStorage can be blocked; that is fine, we just follow the system.
        }
      })();
    </script>
    <Seo {...props} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
