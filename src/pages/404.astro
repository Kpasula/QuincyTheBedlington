---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="That page doesn't exist yet.">
  <div class="container">
    <div class="article-head">
      <h1>That page isn't here</h1>
      <p class="hero__lede">
        It might be a topic that's still being written, or a mistyped address.
        Try the search or head back home.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/">Home</a>
        <a class="btn btn--ghost" href="/search">Search</a>
      </div>
    </div>
  </div>
</BaseLayout>
