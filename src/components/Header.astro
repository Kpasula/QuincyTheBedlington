---
import { SECTIONS, SITE } from '../consts';
const path = Astro.url.pathname.replace(/\/$/, '');
---
<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/">
      <span class="site-header__brand-name">Quincy the Bedlington</span>
      <span class="site-header__brand-tag">{SITE.tagline}</span>
    </a>

    <button class="site-header__toggle" aria-expanded="false" aria-controls="primary-nav" aria-label="Open menu">
      <span aria-hidden="true">☰</span>
    </button>

    <nav id="primary-nav" class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {SECTIONS.map((s) => (
          <li>
            <a
              href={`/${s.slug}`}
              class="site-nav__link"
              aria-current={path === `/${s.slug}` || path.startsWith(`/${s.slug}/`) ? 'page' : undefined}
            >{s.title}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="site-header__search-link" href="/search" aria-label="Search the knowledge base">Search</a>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.site-header__toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('site-nav--open', !open);
  });
</script>
